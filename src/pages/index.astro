---
const name = "James Hazelton";
const title = "Technology & Workforce Strategy Consultant";
const tagline = "Building at the intersection of trucking, workforce development, and AI — with the industry experience to back it up.";

const specialties = [
  {
    title: "Trucking & Workforce Intelligence",
    description: "Former owner-operator, commercial driver, and staffing professional. I don't just build tools for the industry — I've lived it."
  },
  {
    title: "Recruiting & Talent Strategy",
    description: "Deep expertise in high-volume recruiting, candidate sourcing, and placement for hard-to-fill roles. I've built and scaled recruiting operations from the ground up."
  },
  {
    title: "AI-Powered Workforce Solutions",
    description: "Job aggregation platforms, employer intelligence systems, screening and placement automation — purpose-built for high-turnover industries."
  },
  {
    title: "Voice AI & Real-Time Systems",
    description: "LiveKit, Pipecat, Deepgram, Cartesia — building conversational AI agents with real-time voice capabilities powered by Anthropic Claude and OpenAI."
  },
  {
    title: "Data Infrastructure & Scraping",
    description: "Playwright, BeautifulSoup, Outscraper, Pandas. PostgreSQL, Supabase, Airtable. I build pipelines that turn messy industry data into actionable intelligence."
  },
  {
    title: "Full-Stack Development",
    description: "React Native, Expo, FastAPI, Streamlit. From proof-of-concept to production — mobile apps, dashboards, and internal tools designed to move fast."
  }
];

const linkedin = "https://www.linkedin.com/in/hazeltron/";
const github = "https://github.com/hazeltr0n";
const interviewCoach = "https://ai-interview-coach-mu.vercel.app/";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={tagline} />
    <title>{name} | {title}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --color-bg: #0a0a0a;
        --color-surface: #141414;
        --color-text: #f5f5f5;
        --color-muted: #888;
        --color-accent: #3b82f6;
        --color-accent-glow: rgba(59, 130, 246, 0.15);
        --color-border: #2a2a2a;
        --max-width: 800px;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.7;
        min-height: 100vh;
      }

      main {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 4rem 2rem;
      }

      .hero {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: 2.5rem;
        align-items: center;
        margin-bottom: 5rem;
        padding-bottom: 3rem;
        border-bottom: 1px solid var(--color-border);
      }

      .headshot {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--color-border);
        box-shadow: 0 0 40px var(--color-accent-glow);
      }

      .hero-text h1 {
        font-size: 2.5rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        margin-bottom: 0.25rem;
        background: linear-gradient(135deg, #fff 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .title {
        font-size: 1.1rem;
        color: var(--color-accent);
        margin-bottom: 1rem;
        font-weight: 500;
      }

      .tagline {
        font-size: 1.05rem;
        color: var(--color-muted);
        max-width: 500px;
        line-height: 1.6;
      }

      section {
        margin-bottom: 4rem;
      }

      h2 {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-muted);
        margin-bottom: 2rem;
      }

      .specialties {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }

      .specialty {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 1.5rem;
        transition: all 0.2s ease;
      }

      .specialty:hover {
        border-color: var(--color-accent);
        box-shadow: 0 0 30px var(--color-accent-glow);
        transform: translateY(-2px);
      }

      .specialty h3 {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--color-text);
      }

      .specialty p {
        font-size: 0.9rem;
        color: var(--color-muted);
        line-height: 1.5;
      }

      .contact {
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
      }

      .contact-links {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .contact a {
        color: var(--color-accent);
        text-decoration: none;
        font-size: 1rem;
        font-weight: 500;
        transition: color 0.2s ease;
      }

      .contact a:hover {
        color: #60a5fa;
      }

      .contact-form {
        margin-top: 2rem;
        display: grid;
        gap: 1rem;
        max-width: 500px;
      }

      .contact-form input,
      .contact-form textarea {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 0.875rem 1rem;
        font-size: 1rem;
        color: var(--color-text);
        font-family: inherit;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
      }

      .contact-form input:focus,
      .contact-form textarea:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 20px var(--color-accent-glow);
      }

      .contact-form input::placeholder,
      .contact-form textarea::placeholder {
        color: var(--color-muted);
      }

      .contact-form textarea {
        min-height: 120px;
        resize: vertical;
      }

      .contact-form button {
        background: var(--color-accent);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.875rem 1.5rem;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.2s ease;
        justify-self: start;
      }

      .contact-form button:hover {
        background: #2563eb;
        transform: translateY(-1px);
      }

      .contact-trigger {
        background: transparent;
        border: 1px solid var(--color-accent);
        color: var(--color-accent);
        padding: 0.5rem 1.25rem;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .contact-trigger:hover {
        background: var(--color-accent);
        color: white;
        box-shadow: 0 0 30px var(--color-accent-glow);
      }

      .form-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        z-index: 1000;
      }

      .form-overlay.active {
        opacity: 1;
        visibility: visible;
      }

      .form-modal {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 2.5rem;
        width: 90%;
        max-width: 450px;
        transform: translateY(20px) scale(0.95);
        transition: all 0.3s ease;
        position: relative;
      }

      .form-overlay.active .form-modal {
        transform: translateY(0) scale(1);
      }

      .form-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: none;
        border: none;
        color: var(--color-muted);
        font-size: 1.5rem;
        cursor: pointer;
        transition: color 0.2s ease;
        line-height: 1;
      }

      .form-close:hover {
        color: var(--color-text);
      }

      .form-modal h3 {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #fff 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .form-subtitle {
        color: var(--color-muted);
        margin-bottom: 1.5rem;
      }

      .form-modal .contact-form {
        margin-top: 0;
        max-width: none;
      }

      @media (max-width: 700px) {
        main {
          padding: 2rem 1.5rem;
        }

        .hero {
          grid-template-columns: 1fr;
          text-align: center;
          gap: 1.5rem;
        }

        .headshot {
          margin: 0 auto;
        }

        .tagline {
          margin: 0 auto;
        }

        .hero-text h1 {
          font-size: 2rem;
        }

        .specialties {
          grid-template-columns: 1fr;
        }

        .contact-links {
          flex-direction: column;
          gap: 1rem;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <header class="hero">
        <img src="/james.png" alt="James Hazelton" class="headshot" />
        <div class="hero-text">
          <h1>{name}</h1>
          <p class="title">{title}</p>
          <p class="tagline">{tagline}</p>
        </div>
      </header>

      <section>
        <h2>What I Do</h2>
        <div class="specialties">
          {specialties.map((s) => (
            <div class="specialty">
              <h3>{s.title}</h3>
              <p>{s.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="contact">
        <h2>Connect</h2>
        <div class="contact-links">
          <a href={linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a href={github} target="_blank" rel="noopener">GitHub</a>
          <a href={interviewCoach} target="_blank" rel="noopener">AI Interview Coach</a>
          <button class="contact-trigger" id="contactTrigger">Contact Me</button>
        </div>
        <div class="form-overlay" id="formOverlay">
          <div class="form-modal">
            <button class="form-close" id="formClose">&times;</button>
            <h3>Let's Talk</h3>
            <p class="form-subtitle">Tell me about your project or idea</p>
            <form class="contact-form" action="https://formsubmit.co/e881b143aa23091e38d27080ea087277" method="POST">
              <input type="hidden" name="_subject" value="New contact from hazeltonres.com" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="text" name="name" placeholder="Your name" required />
              <input type="email" name="email" placeholder="Your email" required />
              <input type="tel" name="phone" placeholder="Your phone (optional)" />
              <textarea name="message" placeholder="What can I help you with?" required></textarea>
              <button type="submit">Send Message</button>
            </form>
          </div>
        </div>
      </section>
    </main>
    <script>
      const trigger = document.getElementById('contactTrigger');
      const overlay = document.getElementById('formOverlay');
      const closeBtn = document.getElementById('formClose');

      trigger.addEventListener('click', () => {
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      });

      const closeModal = () => {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      };

      closeBtn.addEventListener('click', closeModal);
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closeModal();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
      });
    </script>
  </body>
</html>
