---
const name = "James Hazelton";
const title = "Technology Consultant";
const tagline = "Helping organizations build better software and systems";

const specialties = [
  {
    title: "AI & Automation",
    description: "Voice AI, LLM integration, intelligent automation systems"
  },
  {
    title: "Full-Stack Development",
    description: "Python, React Native, FastAPI, modern web applications"
  },
  {
    title: "System Architecture",
    description: "Scalable infrastructure, API design, database optimization"
  }
];

const email = "james@hazeltonres.com";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={tagline} />
    <title>{name} | {title}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --color-bg: #fafafa;
        --color-text: #1a1a1a;
        --color-muted: #666;
        --color-accent: #2563eb;
        --color-border: #e5e5e5;
        --max-width: 720px;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        padding: 2rem;
      }

      main {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 4rem 0;
      }

      .hero {
        margin-bottom: 4rem;
      }

      h1 {
        font-size: 2.5rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
      }

      .title {
        font-size: 1.25rem;
        color: var(--color-muted);
        margin-bottom: 1.5rem;
      }

      .tagline {
        font-size: 1.125rem;
        max-width: 480px;
      }

      section {
        margin-bottom: 4rem;
      }

      h2 {
        font-size: 0.875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-muted);
        margin-bottom: 1.5rem;
      }

      .specialties {
        display: grid;
        gap: 1.5rem;
      }

      .specialty h3 {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
      }

      .specialty p {
        color: var(--color-muted);
      }

      .contact a {
        color: var(--color-accent);
        text-decoration: none;
        font-size: 1.125rem;
      }

      .contact a:hover {
        text-decoration: underline;
      }

      @media (max-width: 640px) {
        body {
          padding: 1rem;
        }

        main {
          padding: 2rem 0;
        }

        h1 {
          font-size: 2rem;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <header class="hero">
        <h1>{name}</h1>
        <p class="title">{title}</p>
        <p class="tagline">{tagline}</p>
      </header>

      <section>
        <h2>Specialties</h2>
        <div class="specialties">
          {specialties.map((s) => (
            <div class="specialty">
              <h3>{s.title}</h3>
              <p>{s.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="contact">
        <h2>Get in Touch</h2>
        <a href={`mailto:${email}`}>{email}</a>
      </section>
    </main>
  </body>
</html>
