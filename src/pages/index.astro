---
const name = "James Hazelton";
const title = "AI & Workforce Systems Consultant";
const tagline = "Workforce operator who ships. I build AI systems for high-turnover industries — grounded in how the work actually happens, not how a deck describes it.";

const ogDescription = "AI and workforce systems for trucking, recruiting, and high-turnover industries. Built by someone who's lived them.";
const siteUrl = "https://hazeltonres.com";

const bookingUrl = "https://meetings-na2.hubspot.com/james-hazelton";

const specialties = [
  {
    title: "Trucking & Workforce Intelligence",
    description: "Years in high-volume recruiting and workforce operations for trucking and industrial. I build for this space because I know where the gaps are from the inside — not from a vendor deck."
  },
  {
    title: "AI-Powered Workforce Platforms",
    description: "Job aggregation, employer intelligence, screening and placement automation. Purpose-built for industries where 100% turnover is a Tuesday."
  },
  {
    title: "Voice AI & Real-Time Systems",
    description: "LiveKit, Pipecat, Deepgram, Cartesia, Claude, GPT. Conversational agents that sound human and handle real work — intake, screening, scheduling, support."
  }
];

const recentWork = [
  {
    title: "AI Interview Coach",
    blurb: "Voice-based interview prep for job seekers — real-time practice with AI, grounded feedback, zero jargon.",
    href: "https://ai-interview-coach-mu.vercel.app/"
  },
  {
    title: "Workforce AI @ FreeWorld",
    blurb: "Job aggregation, candidate matching, and placement automation for a nonprofit serving returning citizens. Production systems, real volume.",
    href: null
  },
  {
    title: "Async Client Discovery",
    blurb: "Voice-based async discovery tool — clients answer 12 questions on their own time, I get a transcribed digest. Used on live engagements.",
    href: null
  }
];

const linkedin = "https://www.linkedin.com/in/hazeltron/";
const github = "https://github.com/hazeltr0n";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={ogDescription} />
    <title>{name} | {title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={`${name} | ${title}`} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={`${siteUrl}/james.png`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${name} | ${title}`} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={`${siteUrl}/james.png`} />

    <!-- HubSpot tracking (portal 245729528) -->
    <script type="text/javascript" id="hs-script-loader" async defer src="//js.hs-scripts.com/245729528.js"></script>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --color-bg: #0a0a0a;
        --color-surface: #141414;
        --color-text: #f5f5f5;
        --color-muted: #888;
        --color-accent: #3b82f6;
        --color-accent-glow: rgba(59, 130, 246, 0.15);
        --color-border: #2a2a2a;
        --max-width: 800px;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.7;
        min-height: 100vh;
      }

      main {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 4rem 2rem;
      }

      .hero {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: 2.5rem;
        align-items: center;
        margin-bottom: 5rem;
        padding-bottom: 3rem;
        border-bottom: 1px solid var(--color-border);
      }

      .headshot {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--color-border);
        box-shadow: 0 0 40px var(--color-accent-glow);
      }

      .hero-text h1 {
        font-size: 2.5rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        margin-bottom: 0.25rem;
        background: linear-gradient(135deg, #fff 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .title {
        font-size: 1.1rem;
        color: var(--color-accent);
        margin-bottom: 1rem;
        font-weight: 500;
      }

      .tagline {
        font-size: 1.05rem;
        color: var(--color-muted);
        max-width: 500px;
        line-height: 1.6;
      }

      section {
        margin-bottom: 4rem;
      }

      h2 {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-muted);
        margin-bottom: 2rem;
      }

      .specialties {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }

      .specialty {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 1.5rem;
        transition: all 0.2s ease;
      }

      .specialty:hover {
        border-color: var(--color-accent);
        box-shadow: 0 0 30px var(--color-accent-glow);
        transform: translateY(-2px);
      }

      .specialty h3 {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--color-text);
      }

      .specialty p {
        font-size: 0.9rem;
        color: var(--color-muted);
        line-height: 1.5;
      }

      .contact {
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
      }

      .contact-links {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .contact a {
        color: var(--color-accent);
        text-decoration: none;
        font-size: 1rem;
        font-weight: 500;
        transition: color 0.2s ease;
      }

      .contact a:hover {
        color: #60a5fa;
      }

      .contact-form {
        margin-top: 2rem;
        display: grid;
        gap: 1rem;
        max-width: 500px;
      }

      .contact-form input,
      .contact-form textarea {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 0.875rem 1rem;
        font-size: 1rem;
        color: var(--color-text);
        font-family: inherit;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
      }

      .contact-form input:focus,
      .contact-form textarea:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 20px var(--color-accent-glow);
      }

      .contact-form input::placeholder,
      .contact-form textarea::placeholder {
        color: var(--color-muted);
      }

      .contact-form textarea {
        min-height: 120px;
        resize: vertical;
      }

      .contact-form button {
        background: var(--color-accent);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.875rem 1.5rem;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.2s ease;
        justify-self: start;
      }

      .contact-form button:hover {
        background: #2563eb;
        transform: translateY(-1px);
      }

      .contact-form button:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
      }

      .form-status {
        font-size: 0.9rem;
        color: var(--color-muted);
        min-height: 1.2em;
      }

      .form-status.success { color: #34d399; }
      .form-status.error { color: #f87171; }

      .about {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-left: 3px solid var(--color-accent);
        border-radius: 12px;
        padding: 1.75rem 2rem;
        margin-bottom: 4rem;
      }

      .about p {
        color: var(--color-text);
        line-height: 1.7;
        font-size: 1rem;
      }

      .about p + p {
        margin-top: 0.75rem;
        color: var(--color-muted);
      }

      .work {
        display: grid;
        gap: 1rem;
      }

      .work-item {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 10px;
        padding: 1.25rem 1.5rem;
        transition: border-color 0.2s ease;
      }

      .work-item:hover {
        border-color: var(--color-accent);
      }

      .work-item h3 {
        font-size: 1rem;
        margin-bottom: 0.35rem;
      }

      .work-item h3 a {
        color: var(--color-text);
        text-decoration: none;
      }

      .work-item h3 a:hover {
        color: var(--color-accent);
      }

      .work-item p {
        font-size: 0.9rem;
        color: var(--color-muted);
        line-height: 1.5;
      }

      .cta-pitch {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(59, 130, 246, 0.02));
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
      }

      .cta-pitch p {
        color: var(--color-text);
        font-size: 1.05rem;
        margin-bottom: 1.5rem;
        max-width: 560px;
        margin-left: auto;
        margin-right: auto;
      }

      .cta-buttons {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      .btn-primary, .btn-secondary {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all 0.2s ease;
        border: 1px solid transparent;
      }

      .btn-primary {
        background: var(--color-accent);
        color: white;
      }

      .btn-primary:hover {
        background: #2563eb;
        box-shadow: 0 0 30px var(--color-accent-glow);
      }

      .btn-secondary {
        background: transparent;
        border-color: var(--color-accent);
        color: var(--color-accent);
      }

      .btn-secondary:hover {
        background: var(--color-accent);
        color: white;
      }

      .contact-trigger {
        background: transparent;
        border: 1px solid var(--color-accent);
        color: var(--color-accent);
        padding: 0.5rem 1.25rem;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .contact-trigger:hover {
        background: var(--color-accent);
        color: white;
        box-shadow: 0 0 30px var(--color-accent-glow);
      }

      .form-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        z-index: 1000;
      }

      .form-overlay.active {
        opacity: 1;
        visibility: visible;
      }

      .form-modal {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 2.5rem;
        width: 90%;
        max-width: 450px;
        transform: translateY(20px) scale(0.95);
        transition: all 0.3s ease;
        position: relative;
      }

      .form-overlay.active .form-modal {
        transform: translateY(0) scale(1);
      }

      .form-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: none;
        border: none;
        color: var(--color-muted);
        font-size: 1.5rem;
        cursor: pointer;
        transition: color 0.2s ease;
        line-height: 1;
      }

      .form-close:hover {
        color: var(--color-text);
      }

      .form-modal h3 {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #fff 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .form-subtitle {
        color: var(--color-muted);
        margin-bottom: 1.5rem;
      }

      .form-modal .contact-form {
        margin-top: 0;
        max-width: none;
      }

      @media (max-width: 700px) {
        main {
          padding: 2rem 1.5rem;
        }

        .hero {
          grid-template-columns: 1fr;
          text-align: center;
          gap: 1.5rem;
        }

        .headshot {
          margin: 0 auto;
        }

        .tagline {
          margin: 0 auto;
        }

        .hero-text h1 {
          font-size: 2rem;
        }

        .specialties {
          grid-template-columns: 1fr;
        }

        .contact-links {
          flex-direction: column;
          gap: 1rem;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <header class="hero">
        <img src="/james.png" alt="James Hazelton" class="headshot" />
        <div class="hero-text">
          <h1>{name}</h1>
          <p class="title">{title}</p>
          <p class="tagline">{tagline}</p>
        </div>
      </header>

      <section class="about">
        <p>I've run recruiting and workforce operations for hard-to-fill roles — alongside drivers, dispatchers, and back-office teams in industries most software teams never see up close.</p>
        <p>Long enough to know where the real gaps are. Now I build AI systems that close them — grounded in the operational reality, not the slideware.</p>
      </section>

      <section>
        <h2>What I Do</h2>
        <div class="specialties">
          {specialties.map((s) => (
            <div class="specialty">
              <h3>{s.title}</h3>
              <p>{s.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2>Recent Work</h2>
        <div class="work">
          {recentWork.map((w) => (
            <div class="work-item">
              <h3>
                {w.href ? <a href={w.href} target="_blank" rel="noopener">{w.title} →</a> : w.title}
              </h3>
              <p>{w.blurb}</p>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2>Work With Me</h2>
        <div class="cta-pitch">
          <p>Short engagements that ship something real: a working prototype, a production system, or a strategy grounded in how the work actually happens. No decks-for-decks-sake.</p>
          <div class="cta-buttons">
            <a href={bookingUrl} target="_blank" rel="noopener" class="btn-primary">Book 15 min</a>
            <button class="btn-secondary" id="contactTrigger">Send a message</button>
          </div>
        </div>
      </section>

      <section class="contact">
        <h2>Connect</h2>
        <div class="contact-links">
          <a href={linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a href={github} target="_blank" rel="noopener">GitHub</a>
        </div>
        <div class="form-overlay" id="formOverlay">
          <div class="form-modal">
            <button class="form-close" id="formClose">&times;</button>
            <h3>Let's Talk</h3>
            <p class="form-subtitle">Tell me about your project or idea</p>
            <form class="contact-form" id="contactForm" novalidate>
              <input type="text" name="firstname" placeholder="Your name" required />
              <input type="email" name="email" placeholder="Your email" required />
              <input type="tel" name="phone" placeholder="Your phone (optional)" />
              <textarea name="message" placeholder="What can I help you with?" required></textarea>
              <button type="submit" id="submitBtn">Send Message</button>
              <p class="form-status" id="formStatus"></p>
            </form>
          </div>
        </div>
      </section>
    </main>
    <script>
      const trigger = document.getElementById('contactTrigger');
      const overlay = document.getElementById('formOverlay');
      const closeBtn = document.getElementById('formClose');

      trigger.addEventListener('click', () => {
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      });

      const closeModal = () => {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      };

      closeBtn.addEventListener('click', closeModal);
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closeModal();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
      });

      const PORTAL_ID = '245729528';
      const FORM_ID = '3efb7409-46dd-4299-812d-1e5e850e5a8a';
      const form = document.getElementById('contactForm');
      const status = document.getElementById('formStatus');
      const submitBtn = document.getElementById('submitBtn');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        const fields = ['firstname', 'email', 'phone', 'message']
          .map((name) => ({ name, value: String(fd.get(name) || '') }))
          .filter((f) => f.value.length > 0);

        // HubSpot tracking cookie (if the tracking script has loaded)
        const hutk = document.cookie.split('; ').find((c) => c.startsWith('hubspotutk='))?.split('=')[1];

        const body = {
          fields,
          context: {
            pageUri: window.location.href,
            pageName: document.title,
            ...(hutk ? { hutk } : {}),
          },
        };

        submitBtn.disabled = true;
        status.className = 'form-status';
        status.textContent = 'Sending…';

        try {
          const r = await fetch(
            `https://api.hsforms.com/submissions/v3/integration/submit/${PORTAL_ID}/${FORM_ID}`,
            {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            }
          );
          if (!r.ok) throw new Error(`${r.status}: ${await r.text()}`);
          status.className = 'form-status success';
          status.textContent = "Thanks — I'll be in touch shortly.";
          form.reset();
        } catch (err) {
          console.error(err);
          status.className = 'form-status error';
          status.textContent = 'Something broke. Email james@hazeltonres.com directly.';
        } finally {
          submitBtn.disabled = false;
        }
      });
    </script>
  </body>
</html>
