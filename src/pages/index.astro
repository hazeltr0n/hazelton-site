---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Hazelton Senior Citizens — Hazelton, North Dakota" />
    <title>Hazelton Senior Citizens</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: Georgia, 'Times New Roman', serif;
        background: #f9f6f1;
        color: #2c2c2c;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }

      .card {
        text-align: center;
        max-width: 480px;
        width: 100%;
      }

      h1 {
        font-size: 2rem;
        font-weight: normal;
        letter-spacing: 0.02em;
        margin-bottom: 0.5rem;
        color: #1a1a1a;
      }

      .address {
        font-size: 1rem;
        color: #555;
        line-height: 1.8;
        margin-bottom: 2rem;
      }

      .divider {
        border: none;
        border-top: 1px solid #ccc;
        margin: 1.5rem auto;
        width: 60px;
      }

      .status {
        font-size: 1rem;
        color: #666;
        font-style: italic;
        margin-bottom: 1.5rem;
        line-height: 1.6;
      }

      .contact {
        font-size: 0.95rem;
        color: #555;
      }

      .contact-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #999;
        margin-bottom: 0.4rem;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      .contact a {
        color: #4a7c59;
        text-decoration: none;
        font-size: 1rem;
      }

      .contact a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>Hazelton Senior Citizens</h1>
      <div class="address">
        PO Box 333<br />
        Hazelton, ND 58544
      </div>
      <hr class="divider" />
      <p class="status">Our website is currently under construction.<br />Check back soon.</p>
      <hr class="divider" />
      <div class="contact">
        <p class="contact-label">Contact</p>
        <a href="mailto:james@hazeltonres.com">james@hazeltonres.com</a>
      </div>
    </div>
  </body>
</html>
